{
  "name": "til-blog",
  "description": "noriyo_tcp's TIL (Today I Learned) blog built with Astro.",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' astro build",
    "postbuild": "pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "format": "prettier --write .",
    "format:astro": "prettier --write \"src/**/*.astro\"",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^6.3.2",
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/react": "^4.3.0",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.4.1",
    "@astrojs/ts-plugin": "^1.10.4",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@pagefind/default-ui": "^1.4.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/hast": "^3.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.11.1",
    "astro-expressive-code": "^0.41.7",
    "astro-icon": "^1.1.5",
    "emoji-regex": "^10.6.0",
    "gemoji": "^8.1.0",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "hastscript": "^9.0.1",
    "markdown-it": "^14.1.1",
    "mdast-util-directive": "^3.1.0",
    "mdast-util-to-string": "^4.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-github-calendar": "^5.0.5",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "rehype-unwrap-images": "^1.0.0",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "sanitize-html": "^2.17.2",
    "satori": "^0.25.0",
    "satori-html": "^0.3.2",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.3",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/ui": "^4.1.0",
    "jsdom": "^29.0.0",
    "pagefind": "^1.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "sass-embedded": "^1.98.0",
    "vitest": "^4.1.0",
    "zod": "^3.25.76"
  }
}
